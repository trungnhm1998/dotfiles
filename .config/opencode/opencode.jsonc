{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "9router/cu/claude-4.5-haiku",
  "agent": {
    "title": {
      "model": "9router/cu/claude-4.5-haiku",
    },
    "build": {
      "enable1mContext": true,
    },
    "plan": {
      "enable1mContext": true,
    },
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/cu/default",
    },
  },
  "plugin": [
    // "vimcode@git+https://github.com/oribarilan/vimcode.git#v0.8.0",
    // "opencode-claude-auth@latest",
    // "opencode-gemini-auth@latest",
    // "opencode-openai-codex-auth@latest",
    // "opencode-cursor-oauth",
    // "@tarquinen/opencode-dcp@latest",
    // "@franlol/opencode-md-table-formatter@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    // "opencode-supermemory@latest",
    "@rama_nigg/open-cursor@latest",
    "cursor-acp",
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
  },
  "mcp": {
    "unitymcp": {
      "type": "remote",
      "url": "http://localhost:8081/mcp",
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
  },
  "provider": {
    "local-main": {
      "npm": "@ai-sdk/openai-compatible",
      "options": { "baseURL": "http://127.0.0.1:8080/v1" },
      "models": {
        "fast": { "limit": { "context": 65536, "output": 16384 } },
        "big":  { "limit": { "context": 262144, "output": 16384 } },
      },
    },
  },
  "model": "9router/cu/default",
}
