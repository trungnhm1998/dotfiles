{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "small_model": "9router/cu/claude-4.5-haiku",
  "agent": {
    "title": {
      "model": "9router/cu/claude-4.5-haiku",
    },
    "build": {
      "enable1mContext": true,
    },
    "plan": {
      "enable1mContext": true,
    },
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/cu/default",
    },
  },
  "plugin": [
    // "vimcode@git+https://github.com/oribarilan/vimcode.git#v0.8.0",
    // "opencode-claude-auth@latest",
    // "opencode-gemini-auth@latest",
    // "opencode-openai-codex-auth@latest",
    // "opencode-cursor-oauth",
    // "@tarquinen/opencode-dcp@latest",
    // "@franlol/opencode-md-table-formatter@latest",
    "@mohak34/opencode-notifier@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    // "opencode-supermemory@latest",
    "@rama_nigg/open-cursor@latest",
    "cursor-acp",
  ],
  "permission": {
    "edit": "ask",
    "bash": "ask",
  },
  "mcp": {
    "unitymcp": {
      "type": "remote",
      "url": "http://localhost:8081/mcp",
      "enabled": true,
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}",
      },
      "enabled": true,
    },
  },
  "provider": {
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1",
      },
      "models": {
        "auto": {
          "name": "Auto",
          "cost": {
            "input": 1.25,
            "output": 6,
            "cache_read": 0.25,
            "cache_write": 1.25,
          },
        },
        "composer-1.5": {
          "name": "Composer 1.5",
          "cost": {
            "input": 3.5,
            "output": 17.5,
            "cache_read": 0.35,
            "cache_write": 3.5,
          },
        },
        "composer-1": {
          "name": "Composer 1",
        },
        "opus-4.6-thinking": {
          "name": "Claude 4.6 Opus (Thinking)",
        },
        "opus-4.6": {
          "name": "Claude 4.6 Opus",
        },
        "sonnet-4.6": {
          "name": "Claude 4.6 Sonnet",
        },
        "sonnet-4.6-thinking": {
          "name": "Claude 4.6 Sonnet (Thinking)",
        },
        "opus-4.5": {
          "name": "Claude 4.5 Opus",
        },
        "opus-4.5-thinking": {
          "name": "Claude 4.5 Opus (Thinking)",
        },
        "sonnet-4.5": {
          "name": "Claude 4.5 Sonnet",
        },
        "sonnet-4.5-thinking": {
          "name": "Claude 4.5 Sonnet (Thinking)",
        },
        "gpt-5.4-high": {
          "name": "GPT-5.4 High",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5,
              "cache_write": 5,
            },
          },
        },
        "gpt-5.4-medium": {
          "name": "GPT-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "cache_write": 2.5,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5,
              "cache_write": 5,
            },
          },
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "cost": {
            "input": 1.75,
            "output": 14,
            "cache_read": 0.175,
            "cache_write": 1.75,
          },
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
          "cost": {
            "input": 1.75,
            "output": 14,
            "cache_read": 0.175,
            "cache_write": 1.75,
          },
        },
        "gemini-3.1-pro": {
          "name": "Gemini 3.1 Pro",
          "cost": {
            "input": 2,
            "output": 12,
            "cache_read": 0.2,
            "cache_write": 2,
            "context_over_200k": {
              "input": 4,
              "output": 18,
              "cache_read": 0.4,
              "cache_write": 4,
            },
          },
        },
        "gemini-3-pro": {
          "name": "Gemini 3 Pro",
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash",
          "cost": {
            "input": 0.5,
            "output": 3,
            "cache_read": 0.05,
            "cache_write": 0.5,
          },
        },
        "grok": {
          "name": "Grok",
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "cost": {
            "input": 0.6,
            "output": 3,
            "cache_read": 0.1,
            "cache_write": 0.6,
          },
        },
      },
    },
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:20128/v1",
        "apiKey": "{env:NINEROUTER_API_KEY}",
      },
      "models": {
        "cu/default": {
          "name": "cu/default",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
        "cu/claude-4.5-haiku": {
          "name": "cu/claude-4.5-haiku",
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"],
          },
        },
      },
    },
  },
  "model": "9router/cu/default",
}
