// Zed settings — Windows
//
// Unix (macOS / Linux) uses zed/settings.unix.json. Zed has no per-OS settings merge,
// so the deploy scripts symlink the right file per platform (deploy_windows.ps1 links
// this one). Keep the shared keys in sync between the two files.
//
// Zed configuration docs: https://zed.dev/docs/configuring-zed
{
  "cli_default_open_behavior": "new_window",
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "project_panel": {
    "dock": "right",
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "icon_theme": "Catppuccin Frappé",
  "terminal": {
    "shell": {
      "with_arguments": {
        "program": "C:\\Program Files\\PowerShell\\7\\pwsh.exe",
        "args": ["-NoLogo"],
        "title_override": null,
      },
    },
    "font_family": "SauceCodePro Nerd Font Mono",
  },
  "base_keymap": "VSCode",
  "multi_cursor_modifier": "alt",
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 8.0,
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_shape": "bar",
  "cursor_blink": true,
  "buffer_font_fallbacks": ["Fira Code", "Consolas", "Courier New"],
  "buffer_font_family": "JetBrains Mono",
  "colorize_brackets": true,
  "linked_edits": true,
  "show_whitespaces": "all",
  "show_edit_predictions": true,
  "soft_wrap": "none",
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": "Catppuccin Frappé",
}
